<Window x:Class="Guardian.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GuardianOS Dashboard" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Background="#F3F3F3">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="GuardianOS" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="#0078D4"
                       TextAlignment="Center"/>
            <TextBlock Text="Enterprise Windows Security & Remote Administration System" 
                       FontSize="16" 
                       Foreground="#666666"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
            <TextBlock Text="Dashboard" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       TextAlignment="Center"
                       Margin="0,30,0,0"/>
            <ProgressBar Height="4" Margin="0,20,0,0" IsIndeterminate="True"/>
            <TextBlock Text="Loading..." 
                       FontSize="12" 
                       Foreground="#999999"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
